{
  "manifest_version": 3,
  "name": "微信读书笔记导出",
  "description": "一键导出微信读书笔记为 Markdown 格式",
  "version": "1.0.0",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "cookies",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.weread.qq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "微信读书笔记导出"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}